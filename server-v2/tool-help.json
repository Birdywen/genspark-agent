{
  "agent_list": {
    "driver": "agent",
    "desc": "List all agents in Supabase agent_memory",
    "params": {},
    "example": "agent_list",
    "output": "Array of {id, name, description, model, version, capabilities, created_at}"
  },
  "agent_run": {
    "driver": "agent",
    "desc": "Run an agent with a task",
    "params": {
      "name": "(required) agent name",
      "task": "(required) task content to replace {{INPUT}} or ${TASK}",
      "model": "(optional) override agent default model",
      "saveTo": "(optional) save HTML output to local file path",
      "vars": "(optional) JSON string of extra variables"
    },
    "example": "agent_run @name=web-designer-v8 @task=Build a portfolio site"
  },
  "agent_save": {
    "driver": "agent",
    "desc": "Save a new agent to Supabase",
    "params": {
      "name": "(required) agent name",
      "data": "(required) JSON string of agent definition"
    },
    "example": "agent_save @name=my-agent @data={...}"
  },
  "agent_delete": {
    "driver": "agent",
    "desc": "Delete an agent from Supabase",
    "params": {"name": "(required) agent name"},
    "example": "agent_delete @name=my-agent"
  },
  "agent_generate": {
    "driver": "agent",
    "desc": "Generate a new agent via evolve template + askProxy",
    "params": {
      "goal": "(required) what the agent should do",
      "capabilities": "(optional) comma-separated capabilities",
      "pitfalls": "(optional) comma-separated pitfalls to avoid",
      "model": "(optional) model to use, default gpt-5-4"
    },
    "example": "agent_generate @goal=CSS animation expert @capabilities=keyframes,transitions @pitfalls=jank,reflow"
  },
  "run_process": {
    "driver": "shell",
    "desc": "Run a bash command",
    "params": {
      "command": "(required) always 'bash'",
      "stdin": "(required) the script to execute"
    },
    "example": "run_command @command=bash @stdin=echo hello",
    "notes": "Use heredoc for multi-line: @stdin<<SCRIPT...SCRIPT. Max ~100 chars single-line."
  },
  "eval_js": {
    "driver": "browser",
    "desc": "Execute JavaScript in the browser context",
    "params": {"code": "(required) JS code, must return a value_js @code=return document.title",
    "notes": "10s timeout. No Chinese/emoji in return. Use .then() chains with return."
  },
  "take_screenshot": {
    "driver": "browser",
    "desc": "Take a screenshot of current browser tab",
    "params": {},
    "example": "take_screenshot"
  },
  "list_tabs": {
    "driver": "browser",
    "desc": "List open browser tabs",
    "params": {},
    "example": "list_tabs"
  },
  "read_file": {
    "driver": "filesystem",
    "desc": "Read file content",
    "params": {"path": "(required) file path"},
    "example": "read_file @path=/private/tmp/test.txt"
  },
  "write_file": {
    "driver": "filesystem",
    "desc": "Write content to file",
    "params": {
      "path": "(required) file path, must be under /Users/yay/workspace or /private/tmp",
      "content": "(required) file content"
    },
    "example": "write_file @path=/private/tmp/test.txt @content=hello"
  },
  "edit_file": {
    "driver": "filesystem",
    "desc": "Edit file by replacing exact text match",
    "params": {
      "path": "(required) file path",
      "oldText": "(required) exact text to find (must match perfectly)",
      "newText": "(required) replacement text"
    },
    "example": "edit_file @path=/private/tmp/test.txt @oldText=hello @newText=world",
    "notes": "read_file first to get exact text. If >20 lines change, use write_file instead."
  },
  "list_dir": {
    "driver": "filesystem",
    "desc": "List directory contents",
    "params": {"path": "(required) directory path"},
    "example": "list_dir @path=/Users/yay/workspace"
  },
  "find_text": {
    "driver": "filesystem",
    "desc": "Search text in files using tree-sitter",
    "params": {
      "pattern": "(required) search pattern",
      "path": "(optional) directory to search"
    },
    "example": "find_text @pattern=handleToolCall @path=/Users/yay/workspace/genspark-agent"
  },
  "get_symbols": {
    "driver": "filesystem",
    "desc": "Get code symbols (functions, classes) from a file",
    "params": {"path": "(required) file path"},
    "example": "get_symbols @path=/Users/yay/workspace/genspark-agent/server-v2/index.js"
  },
  "vfs_read": {
    "driver": "vfs",
    "desc": "Read from Supabase VFS",
    "params": {
      "slot": "(required) VFS slot name",
      "key": "(optional) message key"
    },
    "example": "vfs_read @slot=toolkit @key=_forged:experience-dialogues"
  },
  "vfs_write": {
    "driver": "vfs",
    "desc": "Write to Supabase VFS",
    "params": {
      "slot": "(required) VFS slot name",
      "key": "(optional) message key",
      "content": "(required) content to write",
      "file": "(optional) read content from local file"
    },
    "example": "vfs_write @slot=toolkit @key=mykey @content=hello"
  },
  "vfs_delete": {
    "driver": "vfs",
    "desc": "Delete from Supabase VFS",
    "params": {
      "slot": "(required) VFS slot name",
      "key": "(optional) message key"
    },
    "example": "vfs_delete @slot=toolkit @key=mykey"
  },
  "vfs_list": {
    "driver": "vfs",
    "desc": "List all keys in a VFS slot",
    "params": {"slot": "(required) VFS slot name"},
    "example": "vfs_list @slot=toolkit"
  },
  "vfs_genspark_write": {
    "driver": "vfs",
    "desc": "Write to Genspark API VFS (not Supabase). Supports @file for large content.",
    "params": {
      "slot": "(required) VFS slot name",
      "key": "(required) message key",
      "content": "(optional) content to write",
      "file": "(optional) read content from local file path"
    },
    "example": "vfs_genspark_write @slot=toolkit @key=mykey @file=/private/tmp/data.json",
    "notes": "Writes to Genspark API, NOT Supabase. Browser eval_js reads this backend."
  },
  "vfs_genspark_read": {
    "driver": "vfs",
    "desc": "Read from Genspark API VFS. Supports @saveTo for large content.",
    "params": {
      "slot": "(required) VFS slot name",
      "key": "(required) message key",
      "saveTo": "(optional) save to local file path, bypasses SSE"
    },
    "example": "vfs_genspark_read @slot=toolkit @key=mykey @saveTo=/private/tmp/out.txt",
    "notes": "Reads from Genspark API, NOT Supabase."
  },
  "bg_run": {
    "driver": "bg",
    "desc": "Run a command in background slot",
    "params": {
      "slot": "(required) slot number",
      "command": "(required) bash command"
    },
    "example": "bg_run @slot=1 @command=node server.js"
  },
  "bg_status": {
    "driver": "bg",
    "desc": "Check background slot status",
    "params": {"slot": "(required) slot number"},
    "example": "bg_status @slot=1",
    "notes": "Use bg_list first to see active slots."
  },
  "bg_kill": {
    "driver": "bg",
    "desc": "Kill a background process",
    "params": {"slot": "(required) slot number"},
    "example": "bg_kill @slot=1"
  },
  "ssh-oracle:exec": {
    "driver": "ssh",
    "desc": "Execute command on Oracle remote server",
    "params": {"command": "(required) command to run"},
    "example": "ssh-oracle:exec @command=uptime"
  },
  "memory_list": {
    "driver": "supabase-memory",
    "desc": "List memory entries from Supabase",
    "params": {"type": "(optional) filter by type"},
    "example": "memory_list @type=agent"
  },
  "memory_read": {
    "driver": "supabase-memory",
    "desc": "Read a memory entry",
    "params": {"name": "(required) entry name"},
    "example": "memory_read @name=forged-scorer"
  },
  "memory_write": {
    "driver": "supabase-memory",
    "desc": "Write a memory entry",
    "params": {
      "name": "(required) entry name",
      "type": "(required) entry type",
      "content": "(required) content"
    },
    "example": "memory_write @name=test @type=note @content=hello"
  },
  "memory_delete": {
    "driver": "supabase-memory",
    "desc": "Delete a memory entry",
    "params": {"name": "(required) entry name"},
    "example": "memory_delete @name=test"
  }
}